<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0;net9.0;net8.0</TargetFrameworks>
    <AssemblyVersion>$(VersionPrefix.Substring(0,3)).0.0</AssemblyVersion>

    <Company>David Group Solutions</Company>
    <Product>Identity</Product>
    <Description>Simplifies authentication and authorization in .NET web APIs with ready-to-use features and helpers.</Description>
    <Authors>David Khachatryan; David Group Solutions</Authors>
    <Copyright>Copyright (c) 2025-2026 David Khachatryan (David Group Solutions)</Copyright>

    <PackageId>DavidGroup.Core.Identity</PackageId>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
    <PackageTags>Identity;Authentication;Authorization;Helpers;Extensions;Utilities;Kit;Instrumentation</PackageTags>
    <PackageProjectUrl>https://github.com/david-group-solutions/identity</PackageProjectUrl>

    <RepositoryUrl>https://github.com/david-group-solutions/identity</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../assets/icon.png" Pack="true" Visible="false" PackagePath="/"/>
    <None Include="../../README.md" Pack="true" Visible="true" PackagePath="/"/>
    <None Include="../../LICENSE.txt" Pack="true" Visible="true" PackagePath="/"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.OpenApi" Version="2.10.0"/>
    <PackageReference Include="Swashbuckle.AspNetCore.SwaggerGen" Version="10.2.3"/>
  </ItemGroup>

  <!-- Per-TFM `ItemGroup` for exceptions only: -->

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Scrutor" Version="7.0.0"/>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.9"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.9"/>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
    <PackageReference Include="Scrutor" Version="6.1.0"/>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="9.0.17"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.17"/>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Scrutor" Version="6.1.0"/>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="8.0.28"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="8.0.2"/>
  </ItemGroup>

</Project>
